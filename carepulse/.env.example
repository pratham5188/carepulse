# ─── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini API key (for MedAssist AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Express session secret — use a long random string in production
SESSION_SECRET=change_this_to_a_random_64_char_string

# ─── Optional ─────────────────────────────────────────────────────────────────
# Email OTP for password reset (Gmail SMTP)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Vercel sets this automatically — do NOT set it manually
# VERCEL=1
